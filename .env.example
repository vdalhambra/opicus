# ============================================================
#  Estructura AI — landing de producto. Variables de entorno.
#  Copia este archivo a .env (gitignored) y rellena lo que uses.
# ============================================================

# --- Frontend (Vite) ---------------------------------------
# Base URL del backend de suscripción.
#   vacío  = mismo origen (despliegue local con server.js, o Vercel).
#   URL    = host externo (p.ej. un túnel al server.js local, o tu deploy
#            de Vercel) cuando el frontend vive en un host estático.
VITE_API_BASE=

# Base path del sitio.
#   '/'                en local y en Vercel.
#   '/estructura-ai/'  en GitHub Pages (project page bajo /<repo>/).
VITE_BASE=/

# --- Backend serverless (api/subscribe.js, sólo en Vercel) -
# Reutiliza las credenciales OAuth de Gmail del agente (00_sistema/gmail/)
# para enviar el correo [ALTA WEB] a la bandeja que sondea el polling.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_INBOX=se1seguridadestructural@gmail.com

# --- Servidor local (server.js) ----------------------------
PORT=8787
PYTHON_BIN=python
# Concede acceso Beta automáticamente al registrar el alta.
# Por defecto DESACTIVADO: la promoción a acceso la hace Antonio a mano
# (política de calidad documentada en CLAUDE.md). Pon 'true' para que un
# alta web quede operativa al instante (drafts siguen pasando revisión).
PRODUCTO_IA_AUTO_GRANT_BETA=false
